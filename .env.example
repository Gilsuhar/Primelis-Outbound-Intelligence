# PostgreSQL-compatible connection string.
# Use a local PostgreSQL database or Supabase project connection string.
# Do not commit real credentials.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Optional direct connection for Supabase migration workflows.
# Often the same as DATABASE_URL for local PostgreSQL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Supabase Auth public browser/server SSR configuration.
# These values are public by design, but still use real values only in local or deployment envs.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Legacy fallback; prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY for new Supabase projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Canonical app URL used for private preview magic-link redirects.
NEXT_PUBLIC_APP_URL=""

# Optional server-side AI provider for draft generation/refinement.
# Leave blank to use the deterministic development fallback.
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
