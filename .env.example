# PostgreSQL-compatible connection string.
# Use a local PostgreSQL database or Supabase project connection string.
# Do not commit real credentials.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Optional direct connection for Supabase migration workflows.
# Often the same as DATABASE_URL for local PostgreSQL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Supabase-ready auth placeholders for a later phase.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
